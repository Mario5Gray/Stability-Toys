# Dockerfile.test - Runtime-aligned image for containerized test execution
# Usage:
#   docker build -f Dockerfile.test --build-arg BACKEND=cpu -t harbor.lan/dreamlab-test:latest .
#   docker compose -f docker-compose.test.yml build test
#   docker compose -f docker-compose.test.yml build test-cuda
#   docker compose -f docker-compose.test.yml run --rm test-unit

ARG TARGETPLATFORM
ARG BACKEND=cpu
ARG GIT_SHA=dev
ARG TORCH_VERSION=2.10.0
ARG TORCHVISION_VERSION=0.25.0
ARG TORCHAUDIO_VERSION=2.10.0

FROM python:3.12-slim AS test

ARG TARGETPLATFORM
ARG BACKEND
ARG GIT_SHA
ARG TORCH_VERSION
ARG TORCHVISION_VERSION
ARG TORCHAUDIO_VERSION

ENV BACKEND_VERSION=${GIT_SHA}
ENV CUDA_HOME=/usr/local/cuda-12.8
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV PYTHONPATH=/app
ENV LOG_LEVEL=INFO
ENV BACKEND=${BACKEND}

WORKDIR /app

RUN set -eux; \
    if [ "${BACKEND}" = "cuda" ]; then \
        arch="$(dpkg --print-architecture)"; \
        if [ "${arch}" != "amd64" ]; then \
            echo "CUDA test image requires linux/amd64 build platform, got ${arch}. Set TEST_PLATFORM=linux/amd64 or use docker compose with platform: linux/amd64." >&2; \
            exit 1; \
        fi; \
    fi; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        build-essential \
        libxext6 \
        libxrender1 \
        libsm6 \
        git \
        ffmpeg \
        libgl1 \
        libglib2.0-0 \
        wget \
        gnupg \
        gpgv; \
    if [ "${BACKEND}" = "cuda" ]; then \
        wget https://developer.download.nvidia.com/compute/cuda/repos/debian12/x86_64/cuda-keyring_1.1-1_all.deb; \
        dpkg -i cuda-keyring_1.1-1_all.deb; \
        apt update -o APT::Key::GPGVCommand=1; \
        apt-get install -y --no-install-recommends \
            cuda-cudart-12-8 \
            libcublas-12-8 \
            libcufft-12-8 \
            libcurand-12-8 \
            libcusolver-12-8 \
            libcusparse-12-8; \
    fi; \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip

COPY requirements.txt /app/requirements.txt
COPY requirements-test.txt /app/requirements-test.txt

RUN if [ "${BACKEND}" != "cuda" ]; then \
        pip install --no-cache-dir \
            torch==${TORCH_VERSION} \
            torchvision==${TORCHVISION_VERSION} \
            torchaudio==${TORCHAUDIO_VERSION} \
            --index-url https://download.pytorch.org/whl/cpu; \
    fi
RUN pip install --no-cache-dir -r /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements-test.txt
RUN if [ "${BACKEND}" = "cuda" ]; then \
        pip install --no-cache-dir nvidia-ml-py; \
        pip install --no-cache-dir --no-deps realesrgan==0.3.0; \
        pip install --no-cache-dir torch==2.10.0 torchvision==0.25.0 torchaudio==2.10.0 xformers==0.0.34 --index-url https://download.pytorch.org/whl/cu128; \
        python -c "import torch, xformers; from xformers import _cpp_lib; from xformers.ops import memory_efficient_attention; assert torch.__version__.startswith('2.10.0'), torch.__version__; assert (torch.version.cuda or '').startswith('12.8'), torch.version.cuda; assert memory_efficient_attention is not None; load_error = getattr(_cpp_lib, '_cpp_library_load_exception', None); assert load_error is None, f'xformers extension failed to load: {load_error}'; print(f'Verified torch={torch.__version__} cuda={torch.version.cuda} xformers={xformers.__version__}')"; \
    fi

COPY server/ /app/server/
COPY persistence/ /app/persistence/
COPY backends/ /app/backends/
COPY invokers/ /app/invokers/
COPY utils/ /app/utils/
COPY tests/ /app/tests/
COPY *.py /app/
COPY *.sh /app/

RUN chmod +x /app/start.sh /app/run_sdxl_tests.sh && \
    mkdir -p /app/logs /conf /store /workflows

CMD ["pytest", "tests/", "-v", "-m", "not slow"]
