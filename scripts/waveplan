#!/usr/bin/env python3
"""waveplan — CLI for managing execution waves from *-execution-waves.json plans."""

import argparse
import json
import sys
from datetime import datetime
from pathlib import Path


PLAN_DIR = Path(__file__).resolve().parent.parent / "docs" / "superpowers" / "plans"


def load_json(path: Path) -> dict:
    """Load and return parsed JSON from path."""
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def save_json(path: Path, data: dict) -> None:
    """Write data as pretty-printed JSON to path."""
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2)
        f.write("\n")


def find_plan_file(plan_arg: str | None) -> Path | None:
    """Find the *-execution-waves.json file in PLAN_DIR. Returns None if none or multiple found."""
    if plan_arg:
        p = Path(plan_arg)
        if not p.exists():
            print(f"ERROR: plan file '{plan_arg}' not found.", file=sys.stderr)
            return None
        return p
    return _find_auto_plan()


def _find_auto_plan() -> Path | None:
    matches = sorted(PLAN_DIR.glob("*-execution-waves.json"))
    if len(matches) == 1:
        return matches[0]
    if len(matches) == 0:
        print("ERROR: no *-execution-waves.json found in docs/superpowers/plans/", file=sys.stderr)
        return None
    print(f"ERROR: multiple *-execution-waves.json files found:\n" + "\n".join(str(m) for m in matches), file=sys.stderr)
    return None


def find_state_file(plan_path: Path) -> Path:
    """Return the state file path alongside the plan."""
    return Path(str(plan_path) + ".state.json")


def load_state(state_path: Path, plan_name: str) -> dict:
    """Load state file, creating it if it doesn't exist."""
    if state_path.exists():
        return load_json(state_path)
    return {"plan": plan_name, "taken": {}, "completed": {}}


def now_str() -> str:
    """Return current timestamp as YYYY-MM-DD HH:MM."""
    return datetime.now().strftime("%Y-%m-%d %H:%M")


def resolve_refs(ref_names: list[str], index: dict) -> list[dict]:
    """Resolve a list of ref names to their full index entries."""
    result = []
    for ref in ref_names:
        entry = index.get(ref, {})
        result.append({"ref": ref, **entry})
    return result


def resolve_fp_refs(ref_names: list[str], fp_index: dict) -> list[dict]:
    """Resolve fp_refs to full entries. fp_index maps ref_name -> FP_ID."""
    result = []
    for ref in ref_names:
        fp_id = fp_index.get(ref, ref)
        result.append({"ref": ref, "fp_id": fp_id})
    return result


def find_plan_ref(units: dict, task_id: str, doc_index: dict, tasks: dict) -> dict | None:
    """Find the plan doc_index entry that corresponds to this task.

    For sub-tasks (e.g. T1.1), the task_id maps to a parent task via the
    'task' field (e.g. T1.1.task == 'T1'). We find the parent task's
    plan_line, then match it against doc_index entries with kind='plan'.
    """
    task = units.get(task_id, {})
    parent_task = task.get("task", task_id)
    parent = tasks.get(parent_task, {})
    plan_line = parent.get("plan_line")
    if plan_line is None:
        return None
    for ref, entry in doc_index.items():
        if entry.get("kind") == "plan" and entry.get("line") == plan_line:
            return {"ref": ref, **entry}
    return None


def is_available(task_id: str, units: dict, state: dict) -> bool:
    """Check if a task is available (not taken/completed and all deps completed)."""
    if task_id in state.get("taken", {}):
        return False
    if task_id in state.get("completed", {}):
        return False
    task = units.get(task_id)
    if task is None:
        return False
    deps = task.get("depends_on", [])
    completed = state.get("completed", {})
    return all(dep in completed for dep in deps)


def next_available_task(units: dict, state: dict) -> str | None:
    """Return the task ID with the lowest wave number that is available, or None."""
    available = [tid for tid in units if is_available(tid, units, state)]
    if not available:
        return None
    # Sort by wave (int), then by task ID string for determinism
    available.sort(key=lambda tid: (units[tid].get("wave", 9999), tid))
    return available[0]


def cmd_peek(args, units: dict, state: dict, doc_index: dict, fp_index: dict, tasks: dict) -> None:
    """Display the next available task without claiming it."""
    tid = next_available_task(units, state)
    if tid is None:
        print("No available tasks.")
        return
    task = units[tid]
    output = {
        "task_id": tid,
        "task": task.get("task"),
        "title": task.get("title"),
        "kind": task.get("kind"),
        "wave": task.get("wave"),
        "plan_line": task.get("plan_line"),
        "plan_ref": find_plan_ref(units, tid, doc_index, tasks),
        "depends_on": task.get("depends_on", []),
        "doc_refs": resolve_refs(task.get("doc_refs", []), doc_index),
        "fp_refs": resolve_fp_refs(task.get("fp_refs", []), fp_index),
        "notes": task.get("notes", []),
    }
    if "command" in task:
        output["command"] = task["command"]
    print(json.dumps(output, indent=2))


def cmd_pop(args, units: dict, state: dict, state_path: Path, doc_index: dict, fp_index: dict, tasks: dict) -> None:
    """Claim the next available task for the given agent."""
    agent = args.agent
    tid = next_available_task(units, state)
    if tid is None:
        print("No available tasks.")
        return
    task = units[tid]
    ts = now_str()
    state.setdefault("taken", {})[tid] = {
        "taken_by": agent,
        "started_at": ts,
    }
    print(f"Claimed {tid}: {task.get('title')} by {agent}")
    # Also print the full task JSON for the agent
    output = {
        "task_id": tid,
        "task": task.get("task"),
        "title": task.get("title"),
        "kind": task.get("kind"),
        "wave": task.get("wave"),
        "plan_line": task.get("plan_line"),
        "plan_ref": find_plan_ref(units, tid, doc_index, tasks),
        "depends_on": task.get("depends_on", []),
        "doc_refs": resolve_refs(task.get("doc_refs", []), doc_index),
        "fp_refs": resolve_fp_refs(task.get("fp_refs", []), fp_index),
        "notes": task.get("notes", []),
    }
    if "command" in task:
        output["command"] = task["command"]
    print(json.dumps(output, indent=2))


def cmd_start_review(args, units: dict, state: dict, state_path: Path) -> None:
    """Start a review for a task."""
    tid = args.task_id
    reviewer = args.reviewer
    if tid not in units:
        print(f"ERROR: task '{tid}' not found in plan.", file=sys.stderr)
        sys.exit(1)
    if tid not in state.get("taken", {}):
        print(f"ERROR: task '{tid}' is not currently taken.", file=sys.stderr)
        sys.exit(1)
    if "review_entered_at" in state["taken"][tid]:
        print(f"ERROR: review for {tid} already started.", file=sys.stderr)
        sys.exit(1)
    ts = now_str()
    state["taken"][tid]["review_entered_at"] = ts
    state["taken"][tid]["reviewer"] = reviewer
    print(f"Review started for {tid}: {units[tid].get('title')} by {reviewer}")


def cmd_end_review(args, units: dict, state: dict, state_path: Path) -> None:
    """End a review for a task."""
    tid = args.task_id
    if tid not in units:
        print(f"ERROR: task '{tid}' not found in plan.", file=sys.stderr)
        sys.exit(1)
    if tid not in state.get("taken", {}):
        print(f"ERROR: task '{tid}' is not currently taken.", file=sys.stderr)
        sys.exit(1)
    if "review_entered_at" not in state["taken"][tid]:
        print(f"ERROR: no active review for {tid}.", file=sys.stderr)
        sys.exit(1)
    ts = now_str()
    state["taken"][tid]["review_ended_at"] = ts
    print(f"Review ended for {tid}: {units[tid].get('title')}")


def cmd_fin(args, units: dict, state: dict) -> None:
    """Mark a task as completed."""
    tid = args.task_id
    if tid not in units:
        print(f"ERROR: task '{tid}' not found in plan.", file=sys.stderr)
        sys.exit(1)
    if tid in state.get("completed", {}):
        print(f"Task {tid} is already completed.", file=sys.stderr)
        sys.exit(1)
    # Check deps
    deps = units[tid].get("depends_on", [])
    incomplete = [d for d in deps if d not in state.get("completed", {})]
    if incomplete:
        print(f"ERROR: task {tid} has incomplete dependencies: {', '.join(incomplete)}", file=sys.stderr)
        sys.exit(1)
    # If review was started but not ended, require review completion first
    taken_entry = state.setdefault("taken", {})
    review_entered = taken_entry.get(tid, {}).get("review_entered_at", "")
    review_ended = taken_entry.get(tid, {}).get("review_ended_at", "")
    if review_entered and not review_ended:
        print(f"ERROR: task {tid} has an active review. End review before completing.", file=sys.stderr)
        sys.exit(1)
    ts = now_str()
    # Ensure started_at and taken_by are set (in case task was fin'd without pop)
    started = taken_entry.get(tid, {}).get("started_at", ts)
    taken_by = taken_entry.get(tid, {}).get("taken_by", "")
    reviewer = taken_entry.get(tid, {}).get("reviewer", "")
    state.setdefault("completed", {})[tid] = {
        "started_at": started,
        "taken_by": taken_by,
        "review_entered_at": review_entered,
        "review_ended_at": review_ended,
        "reviewer": reviewer,
        "finished_at": ts,
    }
    # Remove from taken if present
    state.get("taken", {}).pop(tid, None)
    print(f"Completed {tid}: {units[tid].get('title')}")


def cmd_get(args, units: dict, state: dict, doc_index: dict, fp_index: dict, tasks: dict) -> None:
    """Report tasks based on mode."""
    taken = state.get("taken", {})
    completed = state.get("completed", {})
    mode = args.mode

    if mode == "taken":
        all_ids = sorted(taken.keys())
        if not all_ids:
            print("No tasks taken.")
            return
    elif mode == "open":
        all_ids = sorted([tid for tid in units if is_available(tid, units, state)])
        if not all_ids:
            print("No available tasks.")
            return
    elif mode == "complete":
        all_ids = sorted(completed.keys())
        if not all_ids:
            print("No completed tasks.")
            return
    elif mode in ("all", "agent"):
        agent_filter = mode if mode == "agent" else None
        all_ids = sorted(set(list(taken.keys()) + list(completed.keys())))
        if agent_filter:
            all_ids = [tid for tid in all_ids
                        if taken.get(tid, {}).get("taken_by") == agent_filter
                        or completed.get(tid, {}).get("taken_by") == agent_filter]
            if not all_ids:
                print(f"No tasks for agent '{agent_filter}'.")
                return
        elif not all_ids:
            print("No tasks taken or completed.")
            return
    elif mode.startswith("task-"):
        # Single task lookup
        tid = mode[5:]  # strip "task-"
        if tid not in units:
            print(f"ERROR: task '{tid}' not found in plan.", file=sys.stderr)
            sys.exit(1)
        all_ids = [tid]
    else:
        # Treat unknown mode as agent name
        agent_filter = mode
        all_ids = sorted(set(list(taken.keys()) + list(completed.keys())))
        all_ids = [tid for tid in all_ids
                    if taken.get(tid, {}).get("taken_by") == agent_filter
                    or completed.get(tid, {}).get("taken_by") == agent_filter]
        if not all_ids:
            print(f"No tasks for agent '{agent_filter}'.")
            return

    for tid in all_ids:
        task = units.get(tid, {})
        title = task.get("title", "<unknown>")
        print(f"{tid}, {title}")
        info = taken.get(tid, {})
        comp = completed.get(tid, {})
        started = info.get("started_at") or comp.get("started_at", "—")
        finished = comp.get("finished_at", "—")
        print(f"started: {started}")
        print(f"finished: {finished}")
        agent = info.get("taken_by") or comp.get("taken_by", "")
        if agent:
            print(f"by: {agent}")
        review_entered = info.get("review_entered_at") or comp.get("review_entered_at", "")
        review_ended = info.get("review_ended_at") or comp.get("review_ended_at", "")
        reviewer = info.get("reviewer") or comp.get("reviewer", "")
        if review_entered:
            print(f"entered review: {review_entered}")
        if review_ended:
            print(f"ended review: {review_ended}")
        if reviewer:
            print(f"reviewer: {reviewer}")
        if mode == "open":
            deps = task.get("depends_on", [])
            if deps:
                print(f"depends_on: {', '.join(deps)}")
        plan_ref = find_plan_ref(units, tid, doc_index, tasks)
        if plan_ref:
            print(f"plan: {plan_ref.get('path', '')}:{plan_ref.get('line', '')}")
        doc_refs = task.get("doc_refs", [])
        if doc_refs:
            print("docs:")
            for ref in resolve_refs(doc_refs, doc_index):
                path = ref.get("path", "")
                line = ref.get("line", "")
                print(f"  - {ref['ref']} → {path}:{line}")
        fp_refs = task.get("fp_refs", [])
        if fp_refs:
            print("fprs:")
            for ref in resolve_fp_refs(fp_refs, fp_index):
                print(f"  - {ref['ref']} → {ref['fp_id']}")
        print()


def main() -> None:
    parser = argparse.ArgumentParser(description="waveplan — manage execution waves")
    parser.add_argument("--plan", help="Path to the *-execution-waves.json file")
    parser.add_argument("--state", help="Path to the state JSON file (default: auto-derived from --plan)")
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("peek", help="Show next available task")
    pop_p = sub.add_parser("pop", help="Claim next available task: pop <agent>")
    pop_p.add_argument("agent", help="Agent name claiming the task")
    rev_start_p = sub.add_parser("start_review", help="Start review: start_review <task_id> <reviewer>")
    rev_start_p.add_argument("task_id", help="Task ID to review")
    rev_start_p.add_argument("reviewer", help="Agent name reviewing the task")
    rev_end_p = sub.add_parser("end_review", help="End review: end_review <task_id>")
    rev_end_p.add_argument("task_id", help="Task ID to end review for")
    fin_p = sub.add_parser("fin", help="Mark complete: fin <task_id>")
    fin_p.add_argument("task_id", help="Task ID to complete")
    get_p = sub.add_parser("get", help="Report tasks: get [all|taken|open|complete|task-<id>|<agent>]")
    get_p.add_argument("mode", nargs="?", default="all",
                        help="Filter: all (default), taken, open, complete, task-<id>, or agent name")

    args = parser.parse_args()

    plan_path = find_plan_file(args.plan)
    if plan_path is None:
        sys.exit(1)

    plan = load_json(plan_path)
    units = plan.get("units", {})
    tasks = plan.get("tasks", {})
    doc_index = plan.get("doc_index", {})
    fp_index = plan.get("fp_index", {})
    if args.state:
        state_path = Path(args.state)
    else:
        state_path = find_state_file(plan_path)
    state = load_state(state_path, plan_path.name)

    if args.command == "peek":
        cmd_peek(args, units, state, doc_index, fp_index, tasks)
    elif args.command == "pop":
        cmd_pop(args, units, state, state_path, doc_index, fp_index, tasks)
    elif args.command == "start_review":
        cmd_start_review(args, units, state, state_path)
    elif args.command == "end_review":
        cmd_end_review(args, units, state, state_path)
    elif args.command == "fin":
        cmd_fin(args, units, state)
    elif args.command == "get":
        cmd_get(args, units, state, doc_index, fp_index, tasks)

    # Save state back
    save_json(state_path, state)


if __name__ == "__main__":
    main()