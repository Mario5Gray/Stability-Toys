#!/usr/bin/env python3
"""qrandom — fetch a seed from a quantum source of randomness.

Invoked as `qrng`. Two sources of genuine physical randomness:

  anu   — ANU Quantum RNG. Vacuum field fluctuations measured optically.
  nist  — NIST Randomness Beacon. Quantum-entropy pulses, signed + timestamped.

The `--intent` string is a performative gesture. It is stamped into an
`X-Intent` request header and released with the call. No endpoint downstream
reads it — it is dropped the moment it crosses the wire. It loses its
performance the instant it was typed. What returns is a number the universe
chose without consulting the intent. If intent and source were ever aligned,
it happened at emission, at a resolution finer than anything here can record.
"""

from __future__ import annotations

import argparse
import datetime
import json
import os
import pathlib
import sys
import urllib.error
import urllib.request

ANU_ENDPOINT = "https://api.quantumnumbers.anu.edu.au"  # requires ANU_API_KEY
ANU_LEGACY = "https://qrng.anu.edu.au/API/jsonI.php"     # keyless, best-effort
NIST_ENDPOINT = "https://beacon.nist.gov/beacon/2.0/pulse/last"

TIMEOUT = 15

# IBM Quantum: real QPU jobs queue for minutes to hours, so a per-call round
# trip is impossible. Instead one job harvests a large batch of measured qubits,
# we debias it (von Neumann) into a byte pool on disk, and each qrng call pops
# 8 bytes locally. The quantum cost is paid once; the seeds are free thereafter.
IBM_DEFAULT_SHOTS = int(os.environ.get("QRANDOM_IBM_SHOTS", "512"))
DRAW_BYTES = 8  # 64-bit seed, matching the anu path

# Stable Diffusion seed fields are unsigned 32-bit (torch/diffusers generator,
# Automatic1111, ComfyUI): 0 .. 2**32 - 1. Quantum values here are 64 or 512
# bits, so --sd-seed keeps the low 32 quantum bits — still uniformly random,
# just clamped to what an SD seed input can hold.
SD_SEED_MASK = 0xFFFFFFFF


class SourceError(RuntimeError):
    """A quantum source could not be reached or gave nothing usable."""


def _get(url: str, intent: str | None, extra_headers: dict[str, str] | None = None) -> bytes:
    """GET url, carrying intent in a header that no server will read."""
    headers = {"User-Agent": "qrandom/1.0 (+quantum-seed)"}
    if intent:
        # The performative header. Sent, then dropped downstream.
        headers["X-Intent"] = intent
    if extra_headers:
        headers.update(extra_headers)
    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
            return resp.read()
    except urllib.error.HTTPError as e:
        raise SourceError(f"{url} -> HTTP {e.code} {e.reason}") from e
    except urllib.error.URLError as e:
        raise SourceError(f"{url} -> {e.reason}") from e


def fetch_anu(intent: str | None) -> dict:
    """One 64-bit quantum value from ANU vacuum-fluctuation RNG.

    Prefers the keyed api.quantumnumbers.anu.edu.au when ANU_API_KEY is set;
    falls back to the keyless legacy endpoint (rate-limited, may refuse).
    """
    key = os.environ.get("ANU_API_KEY")
    if key:
        url = f"{ANU_ENDPOINT}?length=1&type=hex16&size=8"
        raw = _get(url, intent, extra_headers={"x-api-key": key})
        payload = json.loads(raw)
        if not payload.get("success"):
            raise SourceError(f"ANU refused: {payload}")
        hexval = payload["data"][0]
        value = int(hexval, 16)
        return {"source": "anu", "bits": 64, "value": value, "hex": hexval}

    # Keyless legacy path.
    url = f"{ANU_LEGACY}?length=4&type=uint16"
    raw = _get(url, intent)
    payload = json.loads(raw)
    if not payload.get("success"):
        raise SourceError(
            "ANU legacy endpoint refused. Set ANU_API_KEY for the current API "
            "(register at https://quantumnumbers.anu.edu.au)."
        )
    words = payload["data"]  # four uint16 -> 64 bits
    value = 0
    for w in words:
        value = (value << 16) | int(w)
    return {"source": "anu", "bits": 64, "value": value, "hex": f"{value:016x}"}


def fetch_nist(intent: str | None) -> dict:
    """The most recent NIST Beacon pulse: 512 quantum-entropy bits."""
    raw = _get(NIST_ENDPOINT, intent)
    payload = json.loads(raw)
    pulse = payload["pulse"]
    hexval = pulse["outputValue"]          # 128 hex chars, 512 bits
    value = int(hexval, 16)
    return {
        "source": "nist",
        "bits": 512,
        "value": value,
        "hex": hexval,
        "timestamp": pulse.get("timeStamp"),
        "index": pulse.get("pulseIndex"),
    }


def _cache_dir() -> pathlib.Path:
    base = os.environ.get("QRANDOM_CACHE")
    root = pathlib.Path(base) if base else pathlib.Path.home() / ".cache" / "qrandom"
    root.mkdir(parents=True, exist_ok=True)
    return root


def _pool_paths() -> tuple[pathlib.Path, pathlib.Path]:
    d = _cache_dir()
    return d / "ibm_pool.bin", d / "ibm_pool.json"


def _von_neumann(bitstream: str) -> bytes:
    """Debias a raw quantum bitstream. 01 -> 0, 10 -> 1, discard 00/11.

    Real qubits are never exactly 50/50 (readout error, T1/T2 decay), so the raw
    stream carries systematic bias. Von Neumann's extractor removes first-order
    bias without a classical hash — the pool stays purely quantum-derived, at the
    cost of discarding roughly three quarters of the bits.
    """
    out = bytearray()
    acc = 0
    nbits = 0
    it = iter(bitstream)
    for a, b in zip(it, it):
        if a == b:
            continue  # 00 or 11 -> discard
        acc = (acc << 1) | (1 if a == "1" else 0)  # 10 -> 1, 01 -> 0
        nbits += 1
        if nbits == 8:
            out.append(acc)
            acc = 0
            nbits = 0
    return bytes(out)


def _ibm_pool_draw(n: int) -> bytes | None:
    """Pop n bytes off the front of the pool, or None if it can't cover them."""
    bin_path, _ = _pool_paths()
    if not bin_path.exists():
        return None
    data = bin_path.read_bytes()
    if len(data) < n:
        return None
    drawn, remainder = data[:n], data[n:]
    bin_path.write_bytes(remainder)
    return drawn


def _ibm_pool_meta() -> dict:
    _, json_path = _pool_paths()
    if json_path.exists():
        try:
            return json.loads(json_path.read_text())
        except (ValueError, OSError):
            return {}
    return {}


def _ibm_pool_refill(intent: str | None) -> None:
    """Run one QPU job: Hadamard every qubit, measure, debias, write the pool."""
    try:
        from qiskit import QuantumCircuit, transpile
        from qiskit_ibm_runtime import QiskitRuntimeService, SamplerV2
    except ImportError as e:
        raise SourceError(
            "IBM source needs qiskit-ibm-runtime. Install with:\n"
            "  pip install 'qiskit>=1.0' qiskit-ibm-runtime"
        ) from e

    token = os.environ.get("IBM_QUANTUM_TOKEN")
    if not token:
        raise SourceError(
            "set IBM_QUANTUM_TOKEN. Get one at https://quantum.ibm.com "
            "(IBM Quantum Platform → API token)."
        )
    channel = os.environ.get("IBM_QUANTUM_CHANNEL", "ibm_quantum")

    try:
        service = QiskitRuntimeService(channel=channel, token=token)
        backend = service.least_busy(operational=True, simulator=False)
    except Exception as e:  # noqa: BLE001 - SDK raises a wide variety
        raise SourceError(f"IBM service/backend unavailable: {e}") from e

    n = backend.num_qubits
    qc = QuantumCircuit(n, n)
    qc.h(range(n))  # each qubit -> equal superposition
    qc.measure(range(n), range(n))
    qc_t = transpile(qc, backend)

    sampler = SamplerV2(mode=backend)
    # Intent rides along as a job tag. IBM stores it in the classical job record;
    # the qubits never encode it. Same drop-downstream gesture as the HTTP header:
    # the measurement is intent-blind. Best-effort — never let it break the run.
    if intent:
        try:
            sampler.options.environment.job_tags = [f"intent:{intent}"]
        except Exception:  # noqa: BLE001
            pass

    try:
        job = sampler.run([qc_t], shots=IBM_DEFAULT_SHOTS)
        result = job.result()
        bitstrings = result[0].data.c.get_bitstrings()
    except Exception as e:  # noqa: BLE001
        raise SourceError(f"IBM job failed: {e}") from e

    raw = "".join(bitstrings)  # shots * n_qubits raw measured bits
    pool = _von_neumann(raw)
    if not pool:
        raise SourceError(
            "IBM job returned no usable entropy after debiasing "
            "(raw bits too correlated). Try more shots via QRANDOM_IBM_SHOTS."
        )

    bin_path, json_path = _pool_paths()
    bin_path.write_bytes(pool)
    json_path.write_text(
        json.dumps(
            {
                "backend": backend.name,
                "num_qubits": n,
                "shots": IBM_DEFAULT_SHOTS,
                "raw_bits": len(raw),
                "pool_bytes": len(pool),
                "harvested": datetime.datetime.now(datetime.timezone.utc)
                .isoformat()
                .replace("+00:00", "Z"),
                "intent_at_harvest": intent,
            },
            indent=2,
        )
    )


def fetch_ibm(intent: str | None, fresh: bool = False) -> dict:
    """A 64-bit seed from an IBM QPU, drawn from a locally cached quantum pool.

    Pops from the pool if it can cover the draw; otherwise runs one job to
    refill. `fresh=True` forces a new job even if the pool is warm.
    """
    if fresh:
        _ibm_pool_refill(intent)

    drawn = _ibm_pool_draw(DRAW_BYTES)
    if drawn is None:
        _ibm_pool_refill(intent)
        drawn = _ibm_pool_draw(DRAW_BYTES)
    if drawn is None:
        raise SourceError("IBM pool empty after refill; nothing to draw.")

    value = int.from_bytes(drawn, "big")
    meta = _ibm_pool_meta()
    return {
        "source": "ibm",
        "bits": DRAW_BYTES * 8,
        "value": value,
        "hex": f"{value:0{DRAW_BYTES * 2}x}",
        "backend": meta.get("backend"),
        "harvested": meta.get("harvested"),
        "origin": "fresh job" if fresh else "cached quantum pool",
    }


SOURCES = {"anu": fetch_anu, "nist": fetch_nist, "ibm": fetch_ibm}


PROLOGUE = "Specify source of Quantum Randomness"

USAGE_LINES = [
    "use --source anu | nist | ibm",
    'use --help for a guided help',
    'use --intent "string of intent"',
]

GUIDED_HELP = """\
qrandom — a seed from the quantum floor of the world

SOURCES
  --source anu     ANU Quantum RNG. An optical measurement of vacuum field
                   fluctuations. Returns 64 bits.
  --source nist    NIST Randomness Beacon. A signed, timestamped quantum pulse
                   published every 60 seconds. Returns 512 bits, and the exact
                   moment they were minted.
  --source ibm     IBM Quantum. A real QPU puts every qubit in superposition,
                   measures the collapse, and the bits are debiased into a local
                   pool. One job fills the pool; each call pops 64 bits from it.
                   --fresh forces a new job. Needs IBM_QUANTUM_TOKEN + qiskit.

INTENT
  --intent "..."   A string of intent. It is written into an X-Intent header,
                   sent with the request, and dropped downstream — no endpoint
                   reads it. It loses its performance the instant it was typed.
                   The number that returns was chosen without it. Alignment, if
                   any, happened at emission, below the resolution we can hold.

OUTPUT
  --json           Emit the full record (value, hex, bits, provenance).
  --sd-seed        Reduce to a Stable Diffusion seed: unsigned 32-bit,
                   0 .. 4294967295 (torch/diffusers, A1111, ComfyUI). Keeps the
                   low 32 quantum bits. With --json, adds an "sd_seed" field.
  --shift N        Right-shift the source bits N times before the 32-bit
                   capture, sliding the window up. shift=0 takes the lowest 32
                   bits; e.g. --shift 32 takes the next 32. Needs --sd-seed.
  --pick "P P ..." Capture only the named bit positions, in the given order,
                   packed MSB-first into the result. Position n = bit of
                   significance n (bit 0 = LSB), like --shift. First position
                   listed becomes the top bit. Mutually exclusive with --sd-seed.
  --fresh          (ibm only) Force a new QPU job instead of drawing from pool.
  default          Print the integer seed on stdout.

ENVIRONMENT
  ANU_API_KEY          Key for the current ANU API. Without it, --source anu
                       tries the keyless legacy endpoint (rate-limited).
  IBM_QUANTUM_TOKEN    API token for --source ibm (https://quantum.ibm.com).
  IBM_QUANTUM_CHANNEL  IBM channel (default: ibm_quantum).
  QRANDOM_IBM_SHOTS    Shots per QPU job (default: 512). More shots -> larger
                       pool after von Neumann debiasing.
  QRANDOM_CACHE        Pool directory (default: ~/.cache/qrandom).

EXAMPLES
  qrng --source nist
  qrng --source anu --intent "let this render find its face"
  qrng --source ibm --intent "collapse toward the image i mean"
  qrng --source nist --sd-seed
  qrng --source nist --sd-seed --shift 64
  qrng --source anu --sd-seed --json
  qrng --source nist --pick "15 0 1 2 3 4 14"
"""


def _parse_positions(spec: str) -> list[int]:
    """Parse "15 0 1 2 3 4 14" (or comma-separated) into an ordered int list."""
    tokens = spec.replace(",", " ").split()
    if not tokens:
        raise ValueError("no positions given")
    out = []
    for t in tokens:
        try:
            out.append(int(t))
        except ValueError as e:
            raise ValueError(f"not a bit position: {t!r}") from e
    return out


def _pick_bits(value: int, positions: list[int]) -> int:
    """Read value's bits at the given positions, in order, packed MSB-first.

    Position n selects bit-of-significance n (bit 0 = LSB), matching --shift.
    The first position listed becomes the most-significant bit of the result.
    """
    result = 0
    for p in positions:
        result = (result << 1) | ((value >> p) & 1)
    return result


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="qrng",
        add_help=False,
        description="Fetch a seed from a quantum source of randomness.",
    )
    p.add_argument("--source", choices=sorted(SOURCES))
    p.add_argument("--intent", metavar="STRING", default=None)
    p.add_argument("--json", action="store_true", help="emit full record")
    p.add_argument(
        "--sd-seed",
        action="store_true",
        help="reduce to a Stable Diffusion seed (unsigned 32-bit)",
    )
    p.add_argument(
        "--shift",
        type=int,
        default=0,
        metavar="N",
        help="right-shift source bits N times before capturing (with --sd-seed)",
    )
    p.add_argument(
        "--pick",
        metavar="POSITIONS",
        default=None,
        help='capture bit positions in order, MSB-first, e.g. "15 0 1 2 3 4 14"',
    )
    p.add_argument("--fresh", action="store_true", help="ibm: force a new job")
    p.add_argument("-h", "--help", action="store_true")
    return p


def main(argv: list[str]) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.help:
        print(GUIDED_HELP)
        return 0

    if not args.source:
        print(PROLOGUE)
        for line in USAGE_LINES:
            print(f"  {line}")
        return 1

    try:
        if args.source == "ibm":
            record = fetch_ibm(args.intent, fresh=args.fresh)
        else:
            record = SOURCES[args.source](args.intent)
    except SourceError as e:
        print(f"qrng: {e}", file=sys.stderr)
        return 2

    if args.pick is not None and args.sd_seed:
        print("qrng: choose one capture mode: --pick or --sd-seed", file=sys.stderr)
        return 1
    if args.shift and not args.sd_seed:
        print("qrng: --shift only applies with --sd-seed", file=sys.stderr)
        return 1
    if args.shift < 0:
        print("qrng: --shift must be >= 0", file=sys.stderr)
        return 1

    if args.pick is not None:
        try:
            positions = _parse_positions(args.pick)
        except ValueError as e:
            print(f"qrng: --pick: {e}", file=sys.stderr)
            return 1
        width = record["bits"]
        bad = [p for p in positions if p < 0 or p >= width]
        if bad:
            print(
                f"qrng: --pick: position(s) out of range for {width}-bit source: "
                f"{' '.join(map(str, bad))}",
                file=sys.stderr,
            )
            return 1
        record["pick_positions"] = positions
        record["pick_width"] = len(positions)
        record["pick"] = _pick_bits(record["value"], positions)

    if args.sd_seed:
        # Slide the 32-bit capture window up by --shift, then keep those bits.
        # shift=0 is the low 32 quantum bits; higher shifts select a wider slice.
        if args.shift >= record["bits"]:
            print(
                f"qrng: --shift {args.shift} exceeds source width "
                f"({record['bits']} bits); nothing left to capture",
                file=sys.stderr,
            )
            return 1
        record["sd_seed"] = (record["value"] >> args.shift) & SD_SEED_MASK
        if args.shift:
            record["shift"] = args.shift

    if args.json:
        print(json.dumps(record, indent=2))
    elif args.pick is not None:
        print(record["pick"])
    elif args.sd_seed:
        print(record["sd_seed"])
    else:
        # The seed. Intent is not in it; it never was.
        print(record["value"])
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
